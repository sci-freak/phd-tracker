{
  "name": "phd-tracker",
  "private": true,
  "version": "1.3.1",
  "main": "electron/main.js",
  "workspaces": [
    "packages/shared",
    "phd-tracker-v2/mobile"
  ],
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test:shared": "node packages/shared/test/run-shared-tests.mjs",
    "test": "npm run test:shared",
    "verify": "npm run test:shared && npm run lint && npm run build",
    "audit:check": "npm audit",
    "functions:install": "npm install --prefix functions",
    "functions:deploy": "npx firebase deploy --only functions",
    "functions:serve": "npx firebase emulators:start --only functions",
    "mobile:install": "npm install --workspace @phd-tracker/mobile",
    "mobile:start": "npm run start --workspace @phd-tracker/mobile",
    "mobile:android": "npm run android --workspace @phd-tracker/mobile",
    "mobile:ios": "npm run ios --workspace @phd-tracker/mobile",
    "mobile:web": "npm run web --workspace @phd-tracker/mobile",
    "mobile:doctor": "npm exec --workspace @phd-tracker/mobile expo-doctor",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && .\\node_modules\\electron\\dist\\electron.exe .\"",
    "electron:build": "npm run build && .\\node_modules\\.bin\\electron-packager.cmd . --overwrite --platform=win32 --arch=x64 --out=release-builds --prune=true"
  },
  "build": {
    "appId": "com.phdtracker.app",
    "productName": "PhD Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "dir",
      "verifyUpdateCodeSignature": false
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phd-tracker/shared": "file:packages/shared",
    "@react-oauth/google": "^0.12.2",
    "firebase": "^12.7.0",
    "gapi-script": "^1.2.0",
    "google-auth-library": "^10.5.0",
    "level": "^10.0.0",
    "moment": "^2.30.1",
    "papaparse": "^5.5.3",
    "react": "19.1.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "baseline-browser-mapping": "^2.10.9",
    "concurrently": "^9.2.1",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-tools": "^15.11.0",
    "globals": "^16.5.0",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}
