{
  "name": "phd-tracker",
  "private": true,
  "version": "2.6.1",
  "main": "electron/main.js",
  "workspaces": [
    "packages/shared",
    "phd-tracker-v2/mobile"
  ],
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test:shared": "node packages/shared/test/run-shared-tests.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test": "npm run test:shared && npm run test:unit",
    "mobile:check-imports": "node scripts/check-mobile-imports.mjs",
    "verify": "npm run test:shared && npm run test:unit && npm run mobile:check-imports && npm run lint && npm run build",
    "audit:check": "npm audit",
    "functions:install": "npm install --prefix functions",
    "functions:deploy": "npx firebase deploy --only functions",
    "functions:serve": "npx firebase emulators:start --only functions",
    "mobile:install": "npm install --workspace @phd-tracker/mobile",
    "mobile:start": "npm run start --workspace @phd-tracker/mobile",
    "mobile:android": "npm run android --workspace @phd-tracker/mobile",
    "mobile:ios": "npm run ios --workspace @phd-tracker/mobile",
    "mobile:web": "npm run web --workspace @phd-tracker/mobile",
    "mobile:doctor": "npm exec --workspace @phd-tracker/mobile expo-doctor",
    "mobile:android:devclient": "npm exec --workspace @phd-tracker/mobile -- eas-cli build --platform android --profile development",
    "mobile:android:preview": "npm exec --workspace @phd-tracker/mobile -- eas-cli build --platform android --profile preview",
    "mobile:android:production": "npm exec --workspace @phd-tracker/mobile -- eas-cli build --platform android --profile production",
    "mobile:android:submit": "npm exec --workspace @phd-tracker/mobile -- eas-cli submit --platform android --profile production --latest",
    "mobile:android:local": "npm exec --workspace @phd-tracker/mobile -- expo run:android",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-packager . --overwrite --platform=win32 --arch=x64 --out=release-builds --prune=true"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phd-tracker/shared": "file:packages/shared",
    "date-fns": "^4.1.0",
    "firebase": "^12.7.0",
    "google-auth-library": "^10.5.0",
    "lucide-react": "^1.14.0",
    "papaparse": "^5.5.3",
    "react": "19.1.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.1.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "baseline-browser-mapping": "^2.10.9",
    "concurrently": "^9.2.1",
    "electron": "^39.2.3",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-tools": "^15.11.0",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "vite": "^7.2.4",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.3"
  }
}
