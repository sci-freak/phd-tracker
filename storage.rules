rules_version = '2';

// Users can read and write only under their own userspace.
// Structure:
//   users/{uid}/applications/{appId}/...   - attachments for an application
//   users/{uid}/**                          - anything else owned by the user
//
// Deploy with:  npx firebase deploy --only storage
// (note: use "storage", not "storage:rules" — the latter is only valid with named targets)
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
